# Optional overrides for local dev when other tools occupy default ports.
# Copy to .env.local (gitignored) and uncomment/customize as needed.
# GATEWAY_HOST_PORT=18080
# QUERY_HOST_PORT=18081
# INGESTER_OTLP_GRPC_HOST_PORT=14317
# INGESTER_OTLP_HTTP_HOST_PORT=14318
# LOG_INGESTER_OTLP_GRPC_HOST_PORT=14327
# LOG_INGESTER_OTLP_HTTP_HOST_PORT=14328
# topo-engine admin port (Prom /metrics, /healthz, /livez). Override locally
# if 8084 conflicts with another tool (SLICE-3).
# TOPO_ENGINE_ADMIN_HOST_PORT=18084
# FRONTEND_HOST_PORT=13000
