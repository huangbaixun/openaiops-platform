{
	local_certs
	auto_https disable_redirects
}

localhost {
	tls internal

	# Query prefix wins first. Mirrors the gateway pattern — strip /api so the
	# backend sees /v1/traces or /v1/logs (post-strip paths everywhere).
	handle /api/v1/traces* {
		uri strip_prefix /api
		reverse_proxy query:8081
	}

	handle /api/v1/logs* {
		uri strip_prefix /api
		reverse_proxy query:8081
	}

	# SLICE-3 topology read paths (services + topology) also live on query.
	# Must precede the /api/* catch-all (first-match-wins).
	handle /api/v1/services* {
		uri strip_prefix /api
		reverse_proxy query:8081
	}

	handle /api/v1/topology* {
		uri strip_prefix /api
		reverse_proxy query:8081
	}

	handle /api/v1/annotations* {
		uri strip_prefix /api
		reverse_proxy query:8081
	}

	# All other /api/* go to gateway.
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy gateway:8080
	}

	handle {
		reverse_proxy frontend:80
	}
}
